// Project Nova — Prisma schema
//
// Data conventions (Story 1.3; docs/architecture/database-design.md, RULES.md):
//   - Internal IDs use cuid(); human-facing references get generated numbers.
//   - Money and hours use Decimal — never floating point.
//   - Database enums use SCREAMING_SNAKE_CASE.
//   - Historical records are archived (status flags), never hard-deleted
//     through normal workflows.
//   - Migrations: `prisma migrate dev` locally, `prisma migrate deploy` in
//     deployment. Never edit the production schema manually.
//
// Prisma 7: the connection URL lives in prisma.config.ts (CLI/migrations)
// and in the driver adapter passed to PrismaClient (src/server/database/prisma.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Identity and organizations (Story 1.4) --------------------------------

// All seven roles from docs/architecture/authorization-rbac.md.
// Roles grant nothing by themselves — authorization is evaluated server-side
// as Permission + Resource Scope + Lifecycle State (Story 1.5).
enum Role {
  PARTICIPANT
  SHELTER_SUPERVISOR
  SHELTER_MANAGER
  PROGRAM_COORDINATOR
  GRANT_ADMINISTRATOR
  NOVA_ADMINISTRATOR
  RESTRICTED_REVIEW_SPECIALIST
}

enum OrganizationKind {
  NOVA
  HOST
}

// Archive-not-delete: records are deactivated, never hard-deleted (RULES.md).
enum ActiveStatus {
  ACTIVE
  INACTIVE
}

model User {
  id          String  @id @default(cuid())
  // Clerk identity mapping (Story 1.2). Null until the provisioning webhook
  // links a Clerk account; synthetic seed users have no Clerk identity.
  clerkUserId String? @unique
  email       String  @unique
  displayName String
  // Marks synthetic seed data so the launch checklist's "synthetic test data
  // removed" gate can find it (docs/ops/launch-checklist.md).
  isSynthetic Boolean @default(false)

  memberships Membership[]
  person      Person?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  kind        OrganizationKind
  status      ActiveStatus     @default(ACTIVE)
  isSynthetic Boolean          @default(false)

  sites            OrganizationSite[]
  memberships      Membership[]
  placementMatches PlacementMatch[]
  placements       Placement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationSite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  addressLine1   String?
  city           String?
  region         String?
  postalCode     String?
  status         ActiveStatus @default(ACTIVE)
  // Placement capacity for this site (docs/ops/shelter-onboarding.md system
  // setup; Story 4.1). Available capacity = this minus onboarding/active/
  // paused placements once Placements exist (Epic 5).
  capacity       Int          @default(0)

  placementMatches PlacementMatch[]
  placements       Placement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// --- Applicant identity (Story 2.2) -----------------------------------------

// A real human being, linked 1:1 to a sign-in account. Holding a Person
// record is NOT participant status: no Role, no Membership. Participant
// status is created only on acceptance (Epic 3, Story 3.1). The permanent-
// disqualification marker lands with Story 2.11 once policy wording exists.
model Person {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  legalFirstName String
  legalLastName  String
  dateOfBirth    DateTime @db.Date

  // Permanent-disqualification marker (Story 2.11, ADR-016): set only by the
  // three ADR-016 categories; blocks future application creation (2.3). On
  // the Person, not the Application, so the block survives reapplication.
  disqualifiedAt DateTime?

  applicantProfile ApplicantProfile?
  applications     Application[]
  participant      Participant?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contact and mailing details collected at applicant onboarding.
// Confidential personal classification (docs/architecture/security-privacy.md):
// never exposed to shelters.
model ApplicantProfile {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])

  phone               String
  mailingAddressLine1 String
  mailingAddressLine2 String?
  city                String
  region              String
  postalCode          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Applications (Story 2.3) -----------------------------------------------

// One attempt by a person to enter Project Nova (TERMINOLOGY.md). Transitions
// are action-based only: DRAFT -> SUBMITTED via 2.5's explicit Submit; review
// phases via 2.8/2.9/2.10; terminal decisions via 2.11. Terminal applications
// are never reopened; reapplication creates a NEW record (business-rules.md).
enum ApplicationStatus {
  DRAFT
  SUBMITTED
  ELIGIBILITY_REVIEW
  INTERVIEW
  BACKGROUND_REVIEW
  ACCEPTED
  REJECTED
  DISQUALIFIED
}

model Application {
  id                String @id @default(cuid())
  // Human-facing reference (docs/architecture/database-design.md).
  applicationNumber String @unique
  personId          String
  person            Person @relation(fields: [personId], references: [id])

  status ApplicationStatus @default(DRAFT)

  // Form responses — lenient while DRAFT (partial saves welcome); completeness
  // is enforced only at submission (2.5). Plain-language prompts, no
  // eligibility screening content (that's review policy, 2.8).
  motivation          String?
  workExperience      String?
  animalExperience    String?
  availabilityNotes   String?
  transportationNotes String?

  submittedAt    DateTime?
  decidedAt      DateTime?
  decisionReason String?

  documents         Document[]
  events            ApplicationEvent[]
  caseNotes         CaseNote[]
  eligibilityReview EligibilityReview?
  interviews        Interview[]
  backgroundReview  BackgroundReview?
  enrollment        ProgramEnrollment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // One non-terminal application per person is enforced by a partial unique
  // index added in the migration SQL (Prisma cannot express WHERE clauses):
  //   UNIQUE (personId) WHERE status NOT IN ('ACCEPTED','REJECTED','DISQUALIFIED')

  @@index([personId])
}

// Lifecycle event for one Application status transition (Story 2.5).
// Lifecycle events are distinct from audit events (architecture.md): this is
// the domain-facing "what happened to this application" trail, written in the
// SAME transaction as the status change so no partial transition can exist.
// Every later transition (2.8-2.11) appends here; rows are never updated or
// deleted (archive-not-delete applies doubly to history).
model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  fromStatus  ApplicationStatus
  toStatus    ApplicationStatus
  // Who performed the transition (the applicant for submit; Operations staff
  // for review transitions). Plain id, matching Document.uploadedByUserId.
  actorUserId String

  createdAt DateTime @default(now())

  @@index([applicationId])
}

// --- Eligibility review (Story 2.8; ADR-015) ---------------------------------

enum EligibilityOutcome {
  ELIGIBLE
  NOT_ELIGIBLE
}

// One eligibility review per application (the lifecycle passes through
// ELIGIBILITY_REVIEW exactly once; reapplication is a NEW application).
// The rationale is an internal operational record (Restricted case
// information): never exposed to the applicant beyond 2.6's simplified
// mapping, never to shelters. Outcomes follow the ADR-015 intake rubric —
// offense history is NEVER part of eligibility.
model EligibilityReview {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  reviewerId String
  outcome    EligibilityOutcome?
  rationale  String?
  decidedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Interview (Story 2.9) ----------------------------------------------------

enum InterviewFormat {
  IN_PERSON
  VIRTUAL
}

enum InterviewOutcome {
  ADVANCE
  DO_NOT_ADVANCE
}

// One row per scheduled appointment: rescheduling CREATES a new row so the
// prior time is preserved as history, never silently overwritten. The
// newest row is the current appointment; the outcome is recorded on it.
// The applicant's journey (2.6) sees date/time/format ONLY — interviewer,
// notes, and the recommendation are internal (never applicant or shelter).
model Interview {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  scheduledAt   DateTime
  format        InterviewFormat
  interviewerId String
  outcome       InterviewOutcome?
  notes         String?
  decidedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
}

// --- Background review (Story 2.10; ADR-015/ADR-016) --------------------------

enum BackgroundOutcome {
  CLEAR
  DISQUALIFYING
}

// Records the outcome of a background check conducted through an EXTERNAL
// process (no vendor integration in MVP). One per application. The
// rationale is Highly Restricted (security-privacy.md): never logged,
// excluded from every view model except the restricted internal one, and
// every access and decision writes an AuditEvent. Only holders of the
// restricted backgroundReview permissions may read or write this — never
// implied by any base role, including Program Coordinator.
model BackgroundReview {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  reviewerId String
  outcome    BackgroundOutcome
  rationale  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Internal operational note (Story 2.7 on Applications; Story 5.9 adds
// Placements). Nova Operations only: never surfaced to the participant
// journey or any shelter experience. XOR ownership (database-design.md) —
// EXACTLY one owning context, enforced by a CHECK constraint hand-written
// in the migration SQL (Prisma cannot express it):
//   CHECK ((("applicationId" IS NOT NULL)::int + ("placementId" IS NOT NULL)::int) = 1)
// Both owning relations are RESTRICT: SetNull (Prisma's default for
// optional relations) would violate the XOR CHECK by nulling the only
// owner. Cleanup deletes notes (and their revisions) before their owner.
model CaseNote {
  id            String       @id @default(cuid())
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  placementId   String?
  placement     Placement?   @relation(fields: [placementId], references: [id], onDelete: Restrict)

  authorUserId String
  body         String

  // Edit history (Story 5.9 AC5): every edit archives the prior content
  // as an append-only revision — nothing is overwritten silently.
  revisions CaseNoteRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([placementId])
}

// One archived prior version of a CaseNote, written transactionally with
// the edit that superseded it (Story 5.9 AC5). Append-only; carries the
// SAME Nova-only sensitivity as the note itself.
model CaseNoteRevision {
  id         String   @id @default(cuid())
  caseNoteId String
  caseNote   CaseNote @relation(fields: [caseNoteId], references: [id])

  priorBody      String
  editedByUserId String

  createdAt DateTime @default(now())

  @@index([caseNoteId])
}

// Audit event (Story 2.7): who accessed or did something sensitive, when.
// DISTINCT from lifecycle events (architecture.md): ApplicationEvent records
// what happened to a workflow record; AuditEvent records access and
// administrative activity for security review (security-privacy.md). First
// use: reads of restricted background-review content. Append-only.
model AuditEvent {
  id          String  @id @default(cuid())
  actorUserId String
  // Permission-style action code, e.g. "backgroundReview.view".
  action      String
  subjectType String
  subjectId   String
  // Short, NON-SENSITIVE context — e.g. a decision reason category (2.11).
  // Never rationale, report content, or anything Highly Restricted.
  detail      String?

  createdAt DateTime @default(now())

  @@index([subjectType, subjectId])
  @@index([actorUserId])
}

// --- Placement matching (Epic 4; schema introduced alongside Story 4.1 per
// --- the epic's sequencing note, owned by Story 4.3) --------------------------

// Full lifecycle per docs/product/placement-lifecycle.md. DRAFT, PROPOSED,
// and CHANGE_REQUESTED are the non-terminal statuses; a participant may hold
// at most ONE non-terminal match (partial unique index in the migration
// SQL), mirroring the one-active-placement rule.
enum MatchStatus {
  DRAFT
  PROPOSED
  APPROVED
  CHANGE_REQUESTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

enum ParticipantMatchDecision {
  PENDING
  ACCEPTED
  DECLINED
}

enum ShelterMatchDecision {
  PENDING
  APPROVED
  CHANGE_REQUESTED
  DECLINED
}

// A proposed participant-to-shelter pairing (TERMINOLOGY.md: Placement
// Match). Coordinator-internal while DRAFT — never visible to participants
// or shelters until proposed (4.4). Approval (4.8) creates the separate
// Placement object (ADR-002: separate lifecycles).
model PlacementMatch {
  id                  String            @id @default(cuid())
  participantId       String
  participant         Participant       @relation(fields: [participantId], references: [id])
  programEnrollmentId String
  programEnrollment   ProgramEnrollment @relation(fields: [programEnrollmentId], references: [id])
  hostOrganizationId  String
  hostOrganization    Organization      @relation(fields: [hostOrganizationId], references: [id])
  organizationSiteId  String
  organizationSite    OrganizationSite  @relation(fields: [organizationSiteId], references: [id])

  status              MatchStatus              @default(DRAFT)
  participantDecision ParticipantMatchDecision @default(PENDING)
  shelterDecision     ShelterMatchDecision     @default(PENDING)

  // Candidate arrangement details (editable while DRAFT, 4.3).
  proposedSupervisorId    String?
  proposedSchedule        String?
  proposedStartDate       DateTime? @db.Date
  proposedEndDate         DateTime? @db.Date
  candidateFundingSourceId String?
  candidateFundingSource   FundingSource? @relation(fields: [candidateFundingSourceId], references: [id], onDelete: Restrict)

  // Point-in-time 4.2 result captured at draft creation / re-evaluation
  // (4.3) — the pairing rationale as a historical record.
  compatibilitySnapshot String?
  coordinatorNotes      String?

  // Proposal boundary (Story 4.4): when the match first crossed the
  // organization boundary, and the decision-window target after which a
  // fully undecided proposal is eligible to expire (evaluated on access).
  proposedAt           DateTime?
  decisionWindowEndsAt DateTime?

  // Participant decision track (Story 4.5). The decision OWNER is always
  // the match's participant; recordedBy captures the recording actor —
  // the participant themselves, or a coordinator recording a decision
  // communicated by phone or in person (AC3). One-way per proposal cycle.
  // The note is Operations-visible only: never in shelter or participant
  // view models, never in audit detail.
  participantDecisionAt               DateTime?
  participantDecisionNote             String?
  participantDecisionRecordedByUserId String?

  // Shelter decision track (Story 4.6). Recorded only by a Shelter
  // Manager of the host organization; the note is REQUIRED for Change
  // Requested and Declined so the coordinator has something actionable.
  // Operational content only — shelters never receive or request
  // participant background information, so the note never carries it.
  shelterDecisionAt               DateTime?
  shelterDecisionNote             String?
  shelterDecisionRecordedByUserId String?

  // Final approval (Story 4.8): the explicit human coordinator action
  // (ADR-011) that converts the match into a Placement.
  approvedAt       DateTime?
  approvedByUserId String?

  events             PlacementMatchEvent[]
  resultingPlacement Placement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
  @@index([hostOrganizationId])
  @@index([organizationSiteId])
}

// Append-only lifecycle event for one PlacementMatch transition (Story 4.3),
// written transactionally with the change — same pattern as every other
// workflow record. fromStatus is null for the creation event.
model PlacementMatchEvent {
  id               String         @id @default(cuid())
  placementMatchId String
  placementMatch   PlacementMatch @relation(fields: [placementMatchId], references: [id])

  fromStatus  MatchStatus?
  toStatus    MatchStatus
  actorUserId String

  // Cycle-boundary snapshot (Story 4.7): when a revision or withdrawal
  // closes a proposal cycle, the outgoing decision values AND the
  // shelter's note are archived here before the row's per-cycle fields
  // reset — prior decisions are never silently overwritten (RULES.md).
  // Ops-internal only; never surfaced to shelter or participant views.
  detail String?

  createdAt DateTime @default(now())

  @@index([placementMatchId])
}

// --- Placements (Story 4.8 creates them; Epic 5 owns the lifecycle) ----------

enum PlacementStatus {
  DRAFT
  PROPOSED
  SHELTER_REVIEW
  APPROVED
  ONBOARDING
  ACTIVE
  PAUSED
  COMPLETED
  CONVERTED_TO_PERMANENT
  WITHDRAWN
  TERMINATED
}

// One transitional-employment placement, created ONLY by the 4.8 match
// approval transaction (sourceMatchId is required and unique) and handed
// to Epic 5 at DRAFT for site/supervisor/schedule review (ADR-013,
// ADR-002 separate lifecycles). "One onboarding/active/paused placement
// per participant" is enforced by a partial unique index hand-written in
// the migration SQL (database-design.md) — the hard backstop behind the
// application-level re-check at approval time.
model Placement {
  id              String @id @default(cuid())
  // Human reference (database-design.md), PLC-YYYY-XXXXXX.
  placementNumber String @unique

  participantId       String
  participant         Participant       @relation(fields: [participantId], references: [id])
  programEnrollmentId String
  programEnrollment   ProgramEnrollment @relation(fields: [programEnrollmentId], references: [id])
  hostOrganizationId  String
  hostOrganization    Organization      @relation(fields: [hostOrganizationId], references: [id])
  organizationSiteId  String
  organizationSite    OrganizationSite  @relation(fields: [organizationSiteId], references: [id])
  sourceMatchId       String            @unique
  sourceMatch         PlacementMatch    @relation(fields: [sourceMatchId], references: [id])

  status PlacementStatus @default(DRAFT)

  // Carried over from the approved match; Story 5.2 refines them through
  // the placement's own shelter-review gate (ADR-013's second gate).
  supervisorId    String?
  schedule        String?
  startDate       DateTime?      @db.Date
  endDate         DateTime?      @db.Date
  fundingSourceId String?
  fundingSource   FundingSource? @relation(fields: [fundingSourceId], references: [id], onDelete: Restrict)

  // Coordinator of record (Story 5.2) — confirmed or reassigned during
  // site/supervisor/schedule assignment.
  coordinatorUserId String?

  // The shelter's outstanding change-request note on the review package
  // (Story 5.2): set when the manager returns the package, cleared on the
  // next propose; every note is archived in the event trail first.
  shelterReviewNote String?

  structuredSchedule PlacementSchedule?
  fundingAssignments FundingAssignment[]
  onboardingTasks    OnboardingTask[]
  caseNotes          CaseNote[]
  evaluations        Evaluation[]
  incidents          Incident[]
  employmentOutcome  EmploymentOutcome?

  events PlacementEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
  @@index([hostOrganizationId])
  @@index([organizationSiteId])
}

// Append-only lifecycle event for one Placement transition, written
// transactionally with the change. fromStatus is null at creation.
model PlacementEvent {
  id          String    @id @default(cuid())
  placementId String
  placement   Placement @relation(fields: [placementId], references: [id])

  fromStatus  PlacementStatus?
  toStatus    PlacementStatus
  actorUserId String

  // Cycle-boundary archive (Story 5.2): the shelter's change-request note
  // rides the SHELTER_REVIEW -> DRAFT event, mirroring the match trail's
  // pattern. Ops-internal only.
  detail String?

  createdAt DateTime @default(now())

  @@index([placementId])
}

// --- Structured schedule (Story 5.2) -----------------------------------------

enum ScheduleDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// The placement's working schedule: day/time entries plus a weekly hours
// target. Decimal, never floating point (RULES.md). One current schedule
// per placement; changes overwrite the rows with an audit event recording
// the edit — lifecycle history lives on PlacementEvent.
model PlacementSchedule {
  id          String    @id @default(cuid())
  placementId String    @unique
  placement   Placement @relation(fields: [placementId], references: [id])

  weeklyHoursTarget Decimal @db.Decimal(5, 2)

  days PlacementScheduleDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One working day within a schedule. Times are local wall-clock "HH:MM"
// strings — schedules describe shifts at a physical site, never
// timezone-converted instants.
model PlacementScheduleDay {
  id         String            @id @default(cuid())
  scheduleId String
  schedule   PlacementSchedule @relation(fields: [scheduleId], references: [id])

  day       ScheduleDay
  startTime String
  endTime   String

  @@unique([scheduleId, day])
}

// --- Funding assignments (Story 5.3; ADR-010) ---------------------------------

enum FundingAssignmentStatus {
  ACTIVE
  ENDED
}

// Exactly one ACTIVE funding assignment per placement (ADR-010) — the
// partial unique index enforcing it is hand-written in the migration SQL
// (database-design.md). History is never deleted: ending an assignment
// marks it ENDED with its end date, and replacements append. Money and
// hour caps are Decimal, never floating point (RULES.md). Blended or
// simultaneous funding is explicitly deferred.
model FundingAssignment {
  id              String        @id @default(cuid())
  placementId     String
  placement       Placement     @relation(fields: [placementId], references: [id])
  fundingSourceId String
  fundingSource   FundingSource @relation(fields: [fundingSourceId], references: [id], onDelete: Restrict)

  status    FundingAssignmentStatus @default(ACTIVE)
  startDate DateTime                @db.Date
  endDate   DateTime?               @db.Date

  hourlyRate Decimal? @db.Decimal(8, 2)
  hoursCap   Decimal? @db.Decimal(7, 2)

  assignedByUserId String
  endedByUserId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placementId])
  @@index([fundingSourceId])
}

// --- Documents (Story 2.4) --------------------------------------------------

enum DocumentType {
  GOVERNMENT_ID
  CERTIFICATION
  OTHER
}

enum DocumentStatus {
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

// Uploaded-document METADATA only — file contents live in secure object
// storage (Vercel Blob, ADR-014) and are Highly Restricted
// (docs/architecture/security-privacy.md): never logged, never in view
// models, never exposed to shelters. EXACTLY ONE owning context per
// document (database-design.md): Application (2.4) XOR Certification (3.5),
// enforced by a CHECK constraint in the migration SQL. Replacement
// supersedes (archive-not-delete); partial unique indexes keep one ACTIVE
// document per (application, type) and one per certification.
model Document {
  id              String         @id @default(cuid())
  applicationId   String?
  application     Application?   @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  certificationId String?
  certification   Certification? @relation(fields: [certificationId], references: [id], onDelete: Restrict)

  documentType DocumentType
  status       DocumentStatus @default(ACTIVE)

  fileName    String
  contentType String
  sizeBytes   Int

  // Blob pathname + URL are server-side secrets, excluded from every view model.
  storagePathname String @unique
  storageUrl      String

  uploadedByUserId String
  supersededAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([certificationId])
}

// --- Certifications (Story 3.5; ADR-017) --------------------------------------

// A credential held by a participant (CPR/First Aid, Fear Free, etc.).
// Expiry is COMPUTED from expiresOn — never stored, so it can't go stale.
// requiredForMatching defaults false per ADR-017 (credentials gate task
// eligibility, not universal readiness); when a coordinator marks one
// required, 3.6 treats an expired one as an outstanding blocker. Archive-
// not-delete: corrections are edits; prior values are preserved in the
// audit trail (certification.update events snapshot the previous row).
model Certification {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])

  name     String
  issuer   String
  issuedOn DateTime  @db.Date
  // Valid through this date, inclusive; null = no expiration.
  expiresOn DateTime? @db.Date

  requiredForMatching Boolean      @default(false)
  status              ActiveStatus @default(ACTIVE)

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
}

// --- Enrollment (Story 3.1) ---------------------------------------------------

// A Project Nova program (TERMINOLOGY.md). MVP runs ONE program — the
// default transitional-employment program, resolved by its stable code at
// acceptance time. The onboarding task catalog (3.2) hangs off Program.
model Program {
  id     String       @id @default(cuid())
  // Stable machine code, e.g. "NOVA-TE" — the acceptance flow resolves the
  // default program by code, never by guessing at "the first active row".
  code   String       @unique
  name   String
  status ActiveStatus @default(ACTIVE)

  enrollments      ProgramEnrollment[]
  taskTemplates    OnboardingTaskTemplate[]
  trainingPrograms TrainingProgram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Participant identity (TERMINOLOGY.md): a person accepted into Project
// Nova. Exactly ONE per Person, ever — an alum whose new application is
// accepted REUSES this row and gains a new ProgramEnrollment (3.1 AC3).
// Created only inside the acceptance transaction (2.11); no standalone
// creation path exists.
model Participant {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])

  enrollments     ProgramEnrollment[]
  certifications  Certification[]
  placementMatches PlacementMatch[]
  placements       Placement[]
  employmentOutcomes EmploymentOutcome[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Epic 3 statuses only; Epic 5 extends this enum when placements arrive.
enum EnrollmentStatus {
  ONBOARDING
  READY_FOR_MATCHING
}

// One period of involvement in a program (TERMINOLOGY.md), created 1:1
// with the accepting Application inside the acceptance transaction.
// Enrollment cannot become placement-active manually (business-rules.md).
model ProgramEnrollment {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])
  programId     String
  program       Program     @relation(fields: [programId], references: [id])
  // The accepting application — one enrollment per acceptance.
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  status     EnrollmentStatus @default(ONBOARDING)
  enrolledAt DateTime         @default(now())

  events              EnrollmentEvent[]
  onboardingTasks     OnboardingTask[]
  trainingEnrollments TrainingEnrollment[]
  placementMatches    PlacementMatch[]
  placements          Placement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
}

// The required-task catalog per Program (Story 3.2) — configured/seeded
// data for MVP; no authoring UI. Generation reads this, never writes it.
model OnboardingTaskTemplate {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])

  title                  String
  description            String
  required               Boolean @default(true)
  participantCompletable Boolean @default(false)
  sortOrder              Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
}

enum OnboardingTaskStatus {
  NOT_STARTED
  COMPLETE
}

// One onboarding checklist item (Story 3.2). XOR ownership
// (database-design.md): EXACTLY one owning context — enrollmentId today,
// placementId with Epic 5 (Story 5.4) — enforced by a CHECK constraint in
// the migration SQL (Prisma cannot express it):
//   CHECK ((("enrollmentId" IS NOT NULL)::int + ("placementId" IS NOT NULL)::int) = 1)
// placementId is a plain column until the Placement model exists.
model OnboardingTask {
  id           String             @id @default(cuid())
  // Both owning relations are RESTRICT: SetNull (Prisma's default for
  // optional relations) would violate the XOR CHECK by nulling the only
  // owner. Cleanup deletes tasks before their owning context.
  enrollmentId String?
  enrollment   ProgramEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  // The Story 5.4 owning context: site-specific placement onboarding
  // (ADR-017 Layer 2), XOR with enrollmentId per the CHECK above.
  placementId  String?
  placement    Placement?         @relation(fields: [placementId], references: [id], onDelete: Restrict)

  templateId String?

  title                  String
  description            String
  required               Boolean
  participantCompletable Boolean
  sortOrder              Int                  @default(0)
  status                 OnboardingTaskStatus @default(NOT_STARTED)

  // Who completed it and when (Story 3.3). Cleared on reopen; the
  // correction history lives in the audit trail, not these columns.
  completedAt       DateTime?
  completedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Idempotent generation: one instance per template per enrollment.
  @@unique([enrollmentId, templateId])
  @@index([enrollmentId])
  @@index([placementId])
}

// Lifecycle event for ProgramEnrollment — same append-only pattern as
// ApplicationEvent (database-design.md). fromStatus is null for the
// creation event.
model EnrollmentEvent {
  id           String            @id @default(cuid())
  enrollmentId String
  enrollment   ProgramEnrollment @relation(fields: [enrollmentId], references: [id])

  fromStatus  EnrollmentStatus?
  toStatus    EnrollmentStatus
  actorUserId String

  createdAt DateTime @default(now())

  @@index([enrollmentId])
}

// --- Portable training (Story 3.4; ADR-017) ----------------------------------

enum TrainingEnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  WITHDRAWN
}

enum TrainingCompletionMethod {
  KNOWLEDGE_ASSESSMENT
  PROVIDER_VERIFICATION
  OBSERVED_COMPETENCY
  PRIOR_LEARNING_VERIFICATION
}

// Program-scoped, seeded catalog data. Requiredness lives here so readiness
// can detect a missing TrainingEnrollment attempt (ADR-017).
model TrainingProgram {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])

  code                String
  name                String
  description         String
  requiredForMatching Boolean      @default(true)
  sortOrder           Int          @default(0)
  status              ActiveStatus @default(ACTIVE)

  enrollments TrainingEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, code])
  @@index([programId, sortOrder])
}

// One attempt to complete one TrainingProgram. COMPLETED and WITHDRAWN are
// terminal; re-enrollment creates a new row. A migration-level partial unique
// index prevents two ENROLLED/IN_PROGRESS attempts for the same pair.
model TrainingEnrollment {
  id                  String            @id @default(cuid())
  programEnrollmentId String
  programEnrollment   ProgramEnrollment @relation(fields: [programEnrollmentId], references: [id])
  trainingProgramId   String
  trainingProgram     TrainingProgram   @relation(fields: [trainingProgramId], references: [id])

  status                 TrainingEnrollmentStatus @default(ENROLLED)
  enrolledAt             DateTime                 @db.Date
  expectedCompletionDate DateTime?                @db.Date
  startedAt              DateTime?                @db.Date
  completedAt            DateTime?                @db.Date
  withdrawnAt            DateTime?                @db.Date
  providerName           String?

  completionMethod           TrainingCompletionMethod?
  completionVerifiedByUserId String?
  completionVerifiedAt       DateTime?

  events TrainingEnrollmentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programEnrollmentId])
  @@index([trainingProgramId])
}

// Append-only lifecycle event, written transactionally with creation or a
// transition. effectiveDate is the coordinator-recorded domain date;
// createdAt is when Nova recorded it.
model TrainingEnrollmentEvent {
  id                   String             @id @default(cuid())
  trainingEnrollmentId String
  trainingEnrollment   TrainingEnrollment @relation(fields: [trainingEnrollmentId], references: [id])

  fromStatus    TrainingEnrollmentStatus?
  toStatus      TrainingEnrollmentStatus
  actorUserId   String
  effectiveDate DateTime                  @db.Date

  createdAt DateTime @default(now())

  @@index([trainingEnrollmentId])
}

// --- Employment outcomes (Story 5.8) -------------------------------------------

// The chain's final entity (domain-model.md): Application -> Enrollment
// -> Match -> Placement -> Employment Outcome. Created ONLY inside the
// Converted to Permanent Employment transaction (Story 5.8 AC2) — one
// per placement, never deleted. Minimal MVP fields; outcome follow-up
// tracking is out of scope.
model EmploymentOutcome {
  id            String      @id @default(cuid())
  placementId   String      @unique
  placement     Placement   @relation(fields: [placementId], references: [id])
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])

  hiredOn      DateTime @db.Date
  employerName String
  jobTitle     String?

  recordedByUserId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
}

// --- Evaluations (Story 5.10) -------------------------------------------------

enum EvaluationRating {
  NEEDS_SUPPORT
  DEVELOPING
  MEETS_EXPECTATIONS
  EXCEEDS_EXPECTATIONS
}

// One periodic workplace evaluation submitted by shelter staff against a
// placement (mvp.md places Evaluations under the Shelter Portal). The
// three performance areas are a fixed MVP rubric defined in domain code
// (src/server/domain/evaluation.ts) — one labeled rating per area, never
// color-coded numbers. Submissions are IMMUTABLE: there is no update
// path; a correction is a new evaluation, so history preservation is
// absolute (data-governance.md — never hard-deleted). Participant
// visibility is an open policy question (open-questions.md #5) and
// defaults closed — no participant query path exists.
model Evaluation {
  id          String    @id @default(cuid())
  placementId String
  placement   Placement @relation(fields: [placementId], references: [id])

  authorUserId   String
  // The period/date this evaluation covers, as recorded by the author.
  evaluationDate DateTime @db.Date

  reliabilityRating  EvaluationRating
  taskQualityRating  EvaluationRating
  teamworkRating     EvaluationRating
  strengths          String
  growthAreas        String?

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([placementId])
}

// --- Incidents (Story 5.11) ----------------------------------------------------

// Fixed lists per docs/ops/incident-response.md — authoritative.
enum IncidentCategory {
  SAFETY
  INJURY
  ANIMAL_WELFARE
  ATTENDANCE
  CONDUCT
  PROPERTY
  HARASSMENT
  OTHER
}

enum IncidentSeverity {
  MINOR
  MODERATE
  SERIOUS
  EMERGENCY
}

// The incident's own machine, independent of placement lifecycle:
// Open -> Under Review -> Closed. Never hard-deleted (RULES.md names
// incidents explicitly); closure makes it read-only history.
enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

// One reported workplace incident against a placement
// (docs/ops/incident-response.md; TERMINOLOGY.md). Shelter staff and Nova
// report; Nova Operations owns review, classification confirmation, and
// closure. description is the operational summary every permitted viewer
// reads; restrictedDetail is the HIGHLY RESTRICTED narrative
// (security-privacy.md names "Serious incident investigations") — gated
// behind incident.viewRestricted, excluded from every other view model
// and from any general query path, reads audited.
model Incident {
  id             String @id @default(cuid())
  // Human reference (database-design.md), INC-YYYY-XXXXXX.
  incidentNumber String @unique

  placementId String
  placement   Placement @relation(fields: [placementId], references: [id])

  category   IncidentCategory
  severity   IncidentSeverity
  occurredOn DateTime         @db.Date

  reporterUserId   String
  description      String
  restrictedDetail String?

  status IncidentStatus @default(OPEN)

  // Nova review and closure trail (AC4) — closure is recorded with
  // reviewer, timestamp, and outcome, then the record is history.
  reviewStartedAt DateTime?
  reviewerUserId  String?
  closedAt        DateTime?
  closedByUserId  String?
  closureOutcome  String?

  followUps IncidentFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placementId])
  @@index([status, severity])
}

// Append-only follow-up on an incident (AC3): shelter staff and Nova add
// context over time; category, severity, and closure remain Nova-only.
model IncidentFollowUp {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])

  authorUserId String
  body         String

  createdAt DateTime @default(now())

  @@index([incidentId])
}

// --- Funding (Story 1.8) ----------------------------------------------------

enum FundingSourceKind {
  GRANT
  CONTRACT
  OTHER
}

// Nova-owned reference data: the grant, contract, or approved source that
// funds placements (TERMINOLOGY.md). No monetary amounts here — allocation
// detail and blended funding are out of MVP scope (ADR-010). Never
// hard-deleted: funding assignments (Story 5.3) and funding reports
// (Story 7.2) depend on it.
model FundingSource {
  id        String            @id @default(cuid())
  name      String
  kind      FundingSourceKind
  // Human-readable identifier (e.g. an award number). Optional until grant
  // fields are validated against actual awards (docs/planning/open-questions.md #6).
  code      String?
  status    ActiveStatus      @default(ACTIVE)
  startDate DateTime?         @db.Date
  endDate   DateTime?         @db.Date
  notes     String?

  placementMatches PlacementMatch[]
  placements       Placement[]
  assignments      FundingAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A user's role within one organization. Organization scope for authorization
// derives from ACTIVE memberships only; deactivated memberships are preserved
// as history and grant nothing.
model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role
  status         ActiveStatus @default(ACTIVE)
  deactivatedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One membership row per user + organization + role.
  @@unique([userId, organizationId, role])
  @@index([organizationId])
  @@index([userId])
}

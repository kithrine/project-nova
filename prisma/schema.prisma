// Project Nova — Prisma schema
//
// Data conventions (Story 1.3; docs/architecture/database-design.md, RULES.md):
//   - Internal IDs use cuid(); human-facing references get generated numbers.
//   - Money and hours use Decimal — never floating point.
//   - Database enums use SCREAMING_SNAKE_CASE.
//   - Historical records are archived (status flags), never hard-deleted
//     through normal workflows.
//   - Migrations: `prisma migrate dev` locally, `prisma migrate deploy` in
//     deployment. Never edit the production schema manually.
//
// Prisma 7: the connection URL lives in prisma.config.ts (CLI/migrations)
// and in the driver adapter passed to PrismaClient (src/server/database/prisma.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Identity and organizations (Story 1.4) --------------------------------

// All seven roles from docs/architecture/authorization-rbac.md.
// Roles grant nothing by themselves — authorization is evaluated server-side
// as Permission + Resource Scope + Lifecycle State (Story 1.5).
enum Role {
  PARTICIPANT
  SHELTER_SUPERVISOR
  SHELTER_MANAGER
  PROGRAM_COORDINATOR
  GRANT_ADMINISTRATOR
  NOVA_ADMINISTRATOR
  RESTRICTED_REVIEW_SPECIALIST
}

enum OrganizationKind {
  NOVA
  HOST
}

// Archive-not-delete: records are deactivated, never hard-deleted (RULES.md).
enum ActiveStatus {
  ACTIVE
  INACTIVE
}

model User {
  id          String  @id @default(cuid())
  // Clerk identity mapping (Story 1.2). Null until the provisioning webhook
  // links a Clerk account; synthetic seed users have no Clerk identity.
  clerkUserId String? @unique
  email       String  @unique
  displayName String
  // Marks synthetic seed data so the launch checklist's "synthetic test data
  // removed" gate can find it (docs/ops/launch-checklist.md).
  isSynthetic Boolean @default(false)

  memberships Membership[]
  person      Person?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  kind        OrganizationKind
  status      ActiveStatus     @default(ACTIVE)
  isSynthetic Boolean          @default(false)

  sites       OrganizationSite[]
  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationSite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  addressLine1   String?
  city           String?
  region         String?
  postalCode     String?
  status         ActiveStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// --- Applicant identity (Story 2.2) -----------------------------------------

// A real human being, linked 1:1 to a sign-in account. Holding a Person
// record is NOT participant status: no Role, no Membership. Participant
// status is created only on acceptance (Epic 3, Story 3.1). The permanent-
// disqualification marker lands with Story 2.11 once policy wording exists.
model Person {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  legalFirstName String
  legalLastName  String
  dateOfBirth    DateTime @db.Date

  // Permanent-disqualification marker (Story 2.11, ADR-016): set only by the
  // three ADR-016 categories; blocks future application creation (2.3). On
  // the Person, not the Application, so the block survives reapplication.
  disqualifiedAt DateTime?

  applicantProfile ApplicantProfile?
  applications     Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contact and mailing details collected at applicant onboarding.
// Confidential personal classification (docs/architecture/security-privacy.md):
// never exposed to shelters.
model ApplicantProfile {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])

  phone               String
  mailingAddressLine1 String
  mailingAddressLine2 String?
  city                String
  region              String
  postalCode          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Applications (Story 2.3) -----------------------------------------------

// One attempt by a person to enter Project Nova (TERMINOLOGY.md). Transitions
// are action-based only: DRAFT -> SUBMITTED via 2.5's explicit Submit; review
// phases via 2.8/2.9/2.10; terminal decisions via 2.11. Terminal applications
// are never reopened; reapplication creates a NEW record (business-rules.md).
enum ApplicationStatus {
  DRAFT
  SUBMITTED
  ELIGIBILITY_REVIEW
  INTERVIEW
  BACKGROUND_REVIEW
  ACCEPTED
  REJECTED
  DISQUALIFIED
}

model Application {
  id String @id @default(cuid())
  // Human-facing reference (docs/architecture/database-design.md).
  applicationNumber String @unique
  personId String
  person   Person @relation(fields: [personId], references: [id])

  status ApplicationStatus @default(DRAFT)

  // Form responses — lenient while DRAFT (partial saves welcome); completeness
  // is enforced only at submission (2.5). Plain-language prompts, no
  // eligibility screening content (that's review policy, 2.8).
  motivation          String?
  workExperience      String?
  animalExperience    String?
  availabilityNotes   String?
  transportationNotes String?

  submittedAt    DateTime?
  decidedAt      DateTime?
  decisionReason String?

  documents         Document[]
  events            ApplicationEvent[]
  caseNotes         CaseNote[]
  eligibilityReview EligibilityReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId])
  // One non-terminal application per person is enforced by a partial unique
  // index added in the migration SQL (Prisma cannot express WHERE clauses):
  //   UNIQUE (personId) WHERE status NOT IN ('ACCEPTED','REJECTED','DISQUALIFIED')
}

// Lifecycle event for one Application status transition (Story 2.5).
// Lifecycle events are distinct from audit events (architecture.md): this is
// the domain-facing "what happened to this application" trail, written in the
// SAME transaction as the status change so no partial transition can exist.
// Every later transition (2.8-2.11) appends here; rows are never updated or
// deleted (archive-not-delete applies doubly to history).
model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  fromStatus ApplicationStatus
  toStatus   ApplicationStatus
  // Who performed the transition (the applicant for submit; Operations staff
  // for review transitions). Plain id, matching Document.uploadedByUserId.
  actorUserId String

  createdAt DateTime @default(now())

  @@index([applicationId])
}

// --- Eligibility review (Story 2.8; ADR-015) ---------------------------------

enum EligibilityOutcome {
  ELIGIBLE
  NOT_ELIGIBLE
}

// One eligibility review per application (the lifecycle passes through
// ELIGIBILITY_REVIEW exactly once; reapplication is a NEW application).
// The rationale is an internal operational record (Restricted case
// information): never exposed to the applicant beyond 2.6's simplified
// mapping, never to shelters. Outcomes follow the ADR-015 intake rubric —
// offense history is NEVER part of eligibility.
model EligibilityReview {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  reviewerId String
  outcome    EligibilityOutcome?
  rationale  String?
  decidedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Internal operational note on an Application (Story 2.7). Nova Operations
// only: never surfaced to the participant journey (2.6) or any shelter
// experience. Case notes use XOR ownership (database-design.md) — exactly
// one owning context. Application is the ONLY owning context that exists
// today, so applicationId is simply required; when enrollment/placement
// notes arrive (Epics 3/5), expand to nullable columns plus a CHECK
// constraint per the expand/migrate/contract strategy.
model CaseNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  authorUserId String
  body         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
}

// Audit event (Story 2.7): who accessed or did something sensitive, when.
// DISTINCT from lifecycle events (architecture.md): ApplicationEvent records
// what happened to a workflow record; AuditEvent records access and
// administrative activity for security review (security-privacy.md). First
// use: reads of restricted background-review content. Append-only.
model AuditEvent {
  id          String @id @default(cuid())
  actorUserId String
  // Permission-style action code, e.g. "backgroundReview.view".
  action      String
  subjectType String
  subjectId   String
  // Short, NON-SENSITIVE context — e.g. a decision reason category (2.11).
  // Never rationale, report content, or anything Highly Restricted.
  detail      String?

  createdAt DateTime @default(now())

  @@index([subjectType, subjectId])
  @@index([actorUserId])
}

// --- Documents (Story 2.4) --------------------------------------------------

enum DocumentType {
  GOVERNMENT_ID
  OTHER
}

enum DocumentStatus {
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

// Uploaded-document METADATA only — file contents live in secure object
// storage (Vercel Blob, ADR-014) and are Highly Restricted
// (docs/architecture/security-privacy.md): never logged, never in view
// models, never exposed to shelters. One owning context per document
// (database-design.md); Application is the only owner that exists today.
// Replacement supersedes (archive-not-delete); exactly one ACTIVE document
// per (application, type) via a partial unique index in the migration SQL.
model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  documentType DocumentType
  status       DocumentStatus @default(ACTIVE)

  fileName    String
  contentType String
  sizeBytes   Int

  // Blob pathname + URL are server-side secrets, excluded from every view model.
  storagePathname String @unique
  storageUrl      String

  uploadedByUserId String
  supersededAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
}

// --- Funding (Story 1.8) ----------------------------------------------------

enum FundingSourceKind {
  GRANT
  CONTRACT
  OTHER
}

// Nova-owned reference data: the grant, contract, or approved source that
// funds placements (TERMINOLOGY.md). No monetary amounts here — allocation
// detail and blended funding are out of MVP scope (ADR-010). Never
// hard-deleted: funding assignments (Story 5.3) and funding reports
// (Story 7.2) depend on it.
model FundingSource {
  id        String            @id @default(cuid())
  name      String
  kind      FundingSourceKind
  // Human-readable identifier (e.g. an award number). Optional until grant
  // fields are validated against actual awards (docs/planning/open-questions.md #6).
  code      String?
  status    ActiveStatus      @default(ACTIVE)
  startDate DateTime?         @db.Date
  endDate   DateTime?         @db.Date
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A user's role within one organization. Organization scope for authorization
// derives from ACTIVE memberships only; deactivated memberships are preserved
// as history and grant nothing.
model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role
  status         ActiveStatus @default(ACTIVE)
  deactivatedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One membership row per user + organization + role.
  @@unique([userId, organizationId, role])
  @@index([organizationId])
  @@index([userId])
}

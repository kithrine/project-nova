# Project Nova — environment variable template
#
# Copy this file to `.env` and fill in real values.
# NEVER commit real secrets (RULES.md). `.env` and `.env.local` are gitignored;
# this template is the only env file that belongs in the repository.
#
# Environment separation (docs/architecture/environments.md):
#   - Local + Vercel Preview -> the shared NONPRODUCTION Neon database (ADR-006)
#   - Production             -> its own Neon database and secrets, configured in
#                               Vercel project settings (never in a committed file)

# --- Database (Story 1.3) ---------------------------------------------------
# Neon PostgreSQL connection string. Used by the Prisma CLI (prisma.config.ts)
# and the runtime pg adapter (src/server/database/prisma.ts).
# Example shape:
#   postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=""

# Direct (non-pooled) connection for Prisma Migrate. With Neon, this is the
# same string with "-pooler" removed from the host. Falls back to DATABASE_URL
# when unset (fine for non-Neon or non-pooled setups).
DIRECT_DATABASE_URL=""

# --- Authentication (Story 1.2) ----------------------------------------------
# Clerk keys (dashboard.clerk.com -> API Keys). Dev instance keys locally;
# separate production-instance keys go in Vercel project settings.
# These live in .env.local:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# In-app auth pages (non-secret; middleware redirect targets)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Webhook signature verification — created when the webhook endpoint is
# registered in the Clerk dashboard (needs a public URL, i.e. at deploy).
CLERK_WEBHOOK_SIGNING_SECRET=""
